<section class="grid stats"><% stats.forEach(s=>{ %><article class="card stat"><span><%= s.label %></span><strong><%= s.value %></strong></article><% }) %></section>
<section class="grid two"><article class="card"><h2>Seven-day revenue trend</h2><div class="bars"><% trend.forEach(r=>{ const max=Math.max(...trend.map(t=>t.amount),1); %><div><span style="height:<%= Math.max(8,(r.amount/max)*130) %>px"></span><small><%= r.day.slice(5) %><br>₹<%= money(r.amount) %></small></div><% }) %></div></article><article class="card"><h2>Payment mode breakdown</h2><div class="donut"><div>Cash<br><b>₹<%= money(summary.cash) %></b></div><div>Online<br><b>₹<%= money(summary.online) %></b></div></div></article></section>
<section class="grid two"><article class="card"><h2>Inventory health</h2><div class="table-wrap"><table><thead><tr><th>Item</th><th>Main</th><th>Second</th><th>Status</th></tr></thead><tbody><% inventory.forEach(i=>{ %><tr><td><%= i.name %></td><td><%= i.mainFridgeQty %></td><td><%= i.secondFridgeQty %></td><td><span class="badge <%= i.mainFridgeQty<=i.lowStockThreshold?'danger':'ok' %>"><%= i.mainFridgeQty<=i.lowStockThreshold?'Low stock':'Healthy' %></span></td></tr><% }) %></tbody></table></div></article><article class="card"><h2>Manager performance</h2><div class="table-wrap"><table><thead><tr><th>Manager</th><th>Sales</th><th>Pieces</th><th>Cash</th><th>Online</th></tr></thead><tbody><% managers.forEach(m=>{ %><tr><td><%= m.name %></td><td>₹<%= money(m.total) %></td><td><%= m.pieces %></td><td>₹<%= money(m.cash) %></td><td>₹<%= money(m.online) %></td></tr><% }) %></tbody></table></div></article></section>
<section class="grid two"><article class="card"><h2>Top kulfi items today</h2><ul class="feed"><% topItems.forEach(i=>{ %><li><b><%= i.name %></b><span><%= i.qty %> pcs · ₹<%= money(i.amount) %></span></li><% }) %><% if(!topItems.length){ %><li class="empty">No sales yet today.</li><% } %></ul></article><article class="card"><h2>Recent stock movement feed</h2><ul class="feed"><% movements.forEach(m=>{ %><li><b><%= m.name %></b><span><%= m.movementType.replaceAll('_',' ') %> · <%= m.quantityPieces %> pcs</span></li><% }) %></ul></article></section>
