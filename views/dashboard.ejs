<section class="grid stats"><% stats.forEach(s=>{ %><article class="card stat"><span><%= s.label %></span><span class="stat-value"><%= s.value %></span></article><% }) %></section>
<section class="grid two"><article class="card"><h2>Seven-day revenue trend</h2><div class="bars"><% trend.forEach(r=>{ const max=Math.max(...trend.map(t=>t.amount),1); %><div><span style="height:<%= Math.max(8,(r.amount/max)*130) %>px"></span><small><%= r.day.slice(5) %><br>₹<%= money(r.amount) %></small></div><% }) %></div></article><article class="card"><h2>Payment mode breakdown</h2><div class="donut"><div>Cash<br><span>₹<%= money(summary.cash) %></span></div><div>Online<br><span>₹<%= money(summary.online) %></span></div></div></article></section>
<section class="grid two"><article class="card"><h2>Inventory health</h2><div class="table-wrap"><table><thead><tr><th>Item</th><th>Main</th><th>Second</th><th>Status</th></tr></thead><tbody><% inventory.forEach(i=>{ %><tr><td><%= i.name %></td><td><%= i.mainFridgeQty %></td><td><%= i.secondFridgeQty %></td><td><span class="badge danger">Low stock</span></td></tr><% }) %><% if(!inventory.length){ %><tr><td colspan="4" class="empty">No low-stock items right now.</td></tr><% } %></tbody></table></div></article><article class="card"><h2>Manager performance</h2><div class="table-wrap"><table><thead><tr><th>Manager</th><th>Sales</th><th>Pieces</th><th>Cash</th><th>Online</th></tr></thead><tbody><% managers.forEach(m=>{ %><tr><td><%= m.name %></td><td>₹<%= money(m.total) %></td><td><%= m.pieces %></td><td>₹<%= money(m.cash) %></td><td>₹<%= money(m.online) %></td></tr><% }) %></tbody></table></div></article></section>
<section class="grid two"><article class="card"><h2>Top kulfi items today</h2><ul class="feed"><% topItems.forEach(i=>{ %><li><span><%= i.name %></span><span><%= i.qty %> pcs · ₹<%= money(i.amount) %></span></li><% }) %><% if(!topItems.length){ %><li class="empty">No sales yet today.</li><% } %></ul></article><details class="card movement-dropdown"><summary><span>Recent stock movement feed</span><span class="dropdown-arrow">⌄</span></summary><ul class="feed"><% movements.forEach(m=>{ %><li><span><%= m.name %></span><span><%= m.movementType.replaceAll('_',' ') %> · <%= m.quantityPieces %> pcs</span></li><% }) %><% if(!movements.length){ %><li class="empty">No stock movements yet.</li><% } %></ul></details></section>
