<% if (typeof mode !== 'undefined' && mode === 'passwordSetup') { %>
<div class="login-page"><section class="login-card"><img class="login-logo" src="/logo.svg" alt="Desi Mastaani Matka Kulfi logo"><p class="eyebrow">First login security</p><h1>Set your new password</h1><p class="muted">Please replace the temporary password before opening your workspace.</p><% if (error) { %><div class="notice error"><%= error %></div><% } %><form method="post" action="/password-setup" class="stack"><input type="hidden" name="next" value="<%= next || '' %>"><label>New password<input name="password" type="password" minlength="8" required placeholder="At least 8 characters"></label><label>Confirm password<input name="confirmPassword" type="password" minlength="8" required placeholder="Repeat new password"></label><button class="btn primary" type="submit">Save password</button></form></section></div>
<% } else { %>
<div class="login-page"><section class="login-card"><img class="login-logo" src="/logo.svg" alt="Desi Mastaani Matka Kulfi logo"><p class="eyebrow">Franchise Billing Suite</p><h1>Desi Mastaani Matka Kulfi</h1><p class="muted">Secure POS, inventory, returns and owner analytics for daily shop operations.</p><% if (error) { %><div class="notice error"><%= error %></div><% } %><form method="post" action="/login" class="stack"><input type="hidden" name="next" value="<%= next || '' %>"><label>User ID or Email<input name="identifier" required placeholder="1001 or owner@desimastaani.test"></label><label>Password<input name="password" type="password" required placeholder="password123"></label><button class="btn primary" type="submit">Login</button></form><div class="demo"><span>Seed users</span><span>Owner: ID 1001 / owner@desimastaani.test / password123</span><span>Manager: ID 2001 / manager@desimastaani.test / password123</span></div></section></div>
<% } %>
